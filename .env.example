# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Netlify personal access token — https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_API_TOKEN=your_netlify_token_here

# Netlify form IDs — find in Netlify dashboard under Forms
NETLIFY_FORM_ID=your_newsletter_form_id_here
NETLIFY_UNSUBSCRIBE_FORM_ID=your_unsubscribe_form_id_here

# Sender identity (must be a verified domain in Resend)
NEWSLETTER_FROM_EMAIL=newsletter@yourdomain.com
NEWSLETTER_FROM_NAME=Your Company Name

# Optional: BCC yourself on all sends (leave blank to disable)
NEWSLETTER_BCC_EMAIL=

# Test send recipient (used with --test flag)
TEST_EMAIL=your_test_email_here

# Unsubscribe page URL (appended with ?email=... in each email)
UNSUBSCRIBE_BASE_URL=https://yourdomain.com/unsubscribe
